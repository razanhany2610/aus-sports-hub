document.addEventListener('DOMContentLoaded', function() {
    checkUserLoginAndLoadProfile();
});

async function checkUserLoginAndLoadProfile() {
    try {
        const response = await fetch('/AUSSportsHub/user-info', {
            method: 'GET',
            credentials: 'include'
        });
        
        if (response.ok) {
            const userData = await response.json();
            
            if (userData.loggedIn) {
                initializeProfile(userData);
                loadUserStats();
                loadRecentActivity();
                loadUpcomingEvents();
                loadSportsPreferences();
            } else {
                window.location.href = '../login.html';
                return;
            }
        } else {
            throw new Error('Failed to fetch user data');
        }
    } catch (error) {
        console.error('Error checking login status:', error);
        initializeProfileFromLocalStorage();
        loadUserStats();
        loadRecentActivity();
        loadUpcomingEvents();
        loadSportsPreferences();
    }
    
    document.querySelector('.btn-edit-profile').addEventListener('click', function() {
        openEditProfileModal();
    });

    function openEditProfileModal() {
        const userFullName = document.getElementById('userFullName').textContent;
        const userStudentId = document.getElementById('userStudentId').textContent.replace('Student ID: ', '');
        
        const modalHTML = `
            <div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title" id="editProfileModalLabel">
                                <i class="fas fa-user-edit me-2"></i>Edit Profile
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="editProfileForm">
                                <div class="mb-3">
                                    <label for="editFullName" class="form-label">Full Name</label>
                                    <input type="text" class="form-control" id="editFullName" value="${userFullName}" required>
                                </div>
                                <div class="mb-3">
                                    <label for="editStudentId" class="form-label">Student ID</label>
                                    <input type="text" class="form-control" id="editStudentId" value="${userStudentId}" required>
                                </div>
                                <div class="mb-3">
                                    <label for="editCurrentPassword" class="form-label">Current Password</label>
                                    <input type="password" class="form-control" id="editCurrentPassword" placeholder="Enter current password to make changes" required>
                                </div>
                                <div class="mb-3">
                                    <label for="editNewPassword" class="form-label">New Password (Optional)</label>
                                    <input type="password" class="form-control" id="editNewPassword" placeholder="Leave blank to keep current password">
                                    <div class="form-text">Leave empty if you don't want to change your password</div>
                                </div>
                                <div class="mb-3">
                                    <label for="editConfirmPassword" class="form-label">Confirm New Password</label>
                                    <input type="password" class="form-control" id="editConfirmPassword" placeholder="Confirm new password">
                                </div>
                            </form>
                            <div id="editProfileMessage" class="alert d-none"></div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-primary" id="saveProfileBtn">
                                <i class="fas fa-save me-1"></i>Save Changes
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        if (!document.getElementById('editProfileModal')) {
            document.body.insertAdjacentHTML('beforeend', modalHTML);
        }
        
        const editProfileModal = new bootstrap.Modal(document.getElementById('editProfileModal'));
        
        document.getElementById('saveProfileBtn').addEventListener('click', saveProfileChanges);
        document.getElementById('editNewPassword').addEventListener('input', validatePasswordMatch);
        document.getElementById('editConfirmPassword').addEventListener('input', validatePasswordMatch);
        
        editProfileModal.show();
    }

    function validatePasswordMatch() {
        const newPassword = document.getElementById('editNewPassword').value;
        const confirmPassword = document.getElementById('editConfirmPassword').value;
        const messageDiv = document.getElementById('editProfileMessage');
        
        if (newPassword && confirmPassword && newPassword !== confirmPassword) {
            messageDiv.className = 'alert alert-warning';
            messageDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>Passwords do not match';
            messageDiv.classList.remove('d-none');
            return false;
        } else {
            messageDiv.classList.add('d-none');
            return true;
        }
    }

    async function saveProfileChanges() {
        const saveBtn = document.getElementById('saveProfileBtn');
        const messageDiv = document.getElementById('editProfileMessage');
        
        const fullName = document.getElementById('editFullName').value;
        const studentId = document.getElementById('editStudentId').value;
        const currentPassword = document.getElementById('editCurrentPassword').value;
        const newPassword = document.getElementById('editNewPassword').value;
        const confirmPassword = document.getElementById('editConfirmPassword').value;
        
        if (!fullName || !studentId || !currentPassword) {
            messageDiv.className = 'alert alert-danger';
            messageDiv.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>Please fill in all required fields';
            messageDiv.classList.remove('d-none');
            return;
        }
        
        if (newPassword && newPassword !== confirmPassword) {
            messageDiv.className = 'alert alert-warning';
            messageDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>Passwords do not match';
            messageDiv.classList.remove('d-none');
            return;
        }
        
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
        saveBtn.disabled = true;
        
        try {
            const response = await fetch('/AUSSportsHub/edit-profile', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'fullName': fullName,
                    'studentId': studentId,
                    'currentPassword': currentPassword,
                    'newPassword': newPassword
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                messageDiv.className = 'alert alert-success';
                messageDiv.innerHTML = `<i class="fas fa-check-circle me-2"></i>${result.message}`;
                messageDiv.classList.remove('d-none');
                
                document.getElementById('userFullName').textContent = fullName;
                document.getElementById('userStudentId').textContent = `Student ID: ${studentId}`;
                
                localStorage.setItem('userFullName', fullName);
                localStorage.setItem('studentId', studentId);
                
                setTimeout(() => {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('editProfileModal'));
                    modal.hide();
                    
                    showNotification('Profile updated successfully!', 'success');
                }, 1500);
                
            } else {
                messageDiv.className = 'alert alert-danger';
                messageDiv.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>${result.message}`;
                messageDiv.classList.remove('d-none');
                
                saveBtn.innerHTML = '<i class="fas fa-save me-1"></i>Save Changes';
                saveBtn.disabled = false;
            }
            
        } catch (error) {
            console.error('Error updating profile:', error);
            messageDiv.className = 'alert alert-danger';
            messageDiv.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>An error occurred while updating profile';
            messageDiv.classList.remove('d-none');
            
            saveBtn.innerHTML = '<i class="fas fa-save me-1"></i>Save Changes';
            saveBtn.disabled = false;
        }
    }

    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        notification.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            if (notification.parentNode) {
                notification.remove();
            }
        }, 5000);
    }
}

function initializeProfile(userData) {
    localStorage.setItem('userFullName', userData.fullName || 'AUS Student');
    localStorage.setItem('userId', userData.userId || 'Unknown');
    localStorage.setItem('userRole', userData.role || 'Student');
    localStorage.setItem('studentId', userData.studentId || 'Not Available');
    
    document.getElementById('userFullName').textContent = userData.fullName || 'AUS Student';
    document.getElementById('userStudentId').textContent = `Student ID: ${userData.studentId || 'Not Available'}`;
    document.getElementById('userRole').textContent = `${userData.role || 'Student'} at American University of Sharjah`;
    
    const memberSince = userData.createdAt ? new Date(userData.createdAt).getFullYear() : '2024';
    document.getElementById('memberSince').textContent = memberSince;
    
    console.log('Profile initialized with:', userData);
}

function initializeProfileFromLocalStorage() {
    const userFullName = localStorage.getItem('userFullName') || 'AUS Student';
    const studentId = localStorage.getItem('studentId') || 'Not Available';
    const userRole = localStorage.getItem('userRole') || 'Student';
    
    document.getElementById('userFullName').textContent = userFullName;
    document.getElementById('userStudentId').textContent = `Student ID: ${studentId}`;
    document.getElementById('userRole').textContent = `${userRole} at American University of Sharjah`;
    
    const memberSince = localStorage.getItem('memberSince') || '2024';
    document.getElementById('memberSince').textContent = memberSince;
    
    console.log('Profile initialized from localStorage');
}

function loadUserStats() {
    const userRegistrations = getUserEventRegistrations();
    const registeredEvents = Object.keys(userRegistrations).length;
    
    const courtBookings = getCourtBookings();
    const bookedCourts = courtBookings.length;
    
    const attendedEvents = Math.floor(registeredEvents * 0.7);
    
    const uniqueSports = calculateUniqueSports();
    
    updateStatsDisplay(registeredEvents, bookedCourts, attendedEvents, uniqueSports);
    
    updateProgressBars(registeredEvents, uniqueSports);
    
    loadRecentActivity();
    
    loadUpcomingEvents();
    
    loadSportsPreferences();
}

function getUserEventRegistrations() {
    const currentUser = getCurrentUser();
    if (!currentUser) return {};
    
    const userRegistrationsKey = `userEventRegistrations_${currentUser.id}`;
    return JSON.parse(localStorage.getItem(userRegistrationsKey) || '{}');
}

function getCourtBookings() {
    const currentUser = getCurrentUser();
    if (!currentUser) return [];
    
    const userBookingsKey = `userCourtBookings_${currentUser.id}`;
    return JSON.parse(localStorage.getItem(userBookingsKey) || '[]');
}

function updateStatsDisplay(registeredEvents, bookedCourts, attendedEvents, uniqueSports) {
    document.getElementById('eventsRegistered').textContent = registeredEvents;
    document.getElementById('courtsBooked').textContent = bookedCourts;
    document.getElementById('eventsAttended').textContent = attendedEvents;
    document.getElementById('sportsPlayed').textContent = uniqueSports;
}

function calculateUniqueSports() {
    const userRegistrations = getUserEventRegistrations();
    const courtBookings = getCourtBookings();
    const sports = new Set();
    
    Object.values(userRegistrations).forEach(registration => {
        const sportType = extractSportType(registration.eventName);
        if (sportType) sports.add(sportType);
    });
    
    courtBookings.forEach(booking => {
        if (booking.sport) sports.add(booking.sport.toLowerCase());
    });
    
    return sports.size;
}

function extractSportType(eventName) {
    const name = eventName.toLowerCase();
    if (name.includes('basketball')) return 'basketball';
    if (name.includes('football') || name.includes('soccer')) return 'football';
    if (name.includes('padel')) return 'padel';
    if (name.includes('volleyball')) return 'volleyball';
    if (name.includes('tennis')) return 'tennis';
    if (name.includes('swim')) return 'swimming';
    return null;
}

function updateProgressBars(registeredEvents, uniqueSports) {
    const monthlyProgress = Math.min((registeredEvents / 8) * 100, 100);
    document.getElementById('monthlyProgress').textContent = `${registeredEvents}/8 events`;
    document.getElementById('monthlyProgressBar').style.width = `${monthlyProgress}%`;
    
    const sportsProgress = Math.min((uniqueSports / 5) * 100, 100);
    document.getElementById('sportsVariety').textContent = `${uniqueSports}/5 sports`;
    document.getElementById('sportsProgressBar').style.width = `${sportsProgress}%`;
}

function loadRecentActivity() {
    const activityList = document.getElementById('recentActivity');
    const userRegistrations = JSON.parse(localStorage.getItem('userEventRegistrations') || '{}');
    
    if (Object.keys(userRegistrations).length === 0) {
        activityList.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-calendar-plus"></i>
                <p>No recent activity</p>
                <small>Register for events to see your activity here</small>
            </div>
        `;
        return;
    }
    
    const activities = [];
    Object.entries(userRegistrations).forEach(([eventId, registration]) => {
        activities.push({
            type: 'registration',
            eventName: registration.eventName,
            timestamp: new Date(registration.registeredAt),
            eventId: eventId
        });
    });
    
    activities.sort((a, b) => b.timestamp - a.timestamp);
    
    activities.slice(0, 5).forEach(activity => {
        const activityItem = document.createElement('div');
        activityItem.className = 'activity-item';
        
        const timeAgo = getTimeAgo(activity.timestamp);
        
        activityItem.innerHTML = `
            <div class="activity-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <div class="activity-content">
                <h6 class="activity-title">Registered for ${activity.eventName}</h6>
                <p class="activity-time">${timeAgo}</p>
            </div>
        `;
        
        activityList.appendChild(activityItem);
    });
}

function loadUpcomingEvents() {
    const upcomingEvents = document.getElementById('upcomingEvents');
    const userRegistrations = JSON.parse(localStorage.getItem('userEventRegistrations') || '{}');
    
    if (Object.keys(userRegistrations).length === 0) {
        upcomingEvents.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-calendar-day"></i>
                <p>No upcoming events</p>
                <small>Register for events to see them here</small>
            </div>
        `;
        return;
    }
    
    const events = [];
    Object.entries(userRegistrations).forEach(([eventId, registration]) => {
        const eventDate = new Date(registration.registeredAt);
        eventDate.setDate(eventDate.getDate() + Math.floor(Math.random() * 30) + 1);
        
        events.push({
            name: registration.eventName,
            date: eventDate
        });
    });
    
    events.sort((a, b) => a.date - b.date);
    
    events.slice(0, 3).forEach(event => {
        const eventItem = document.createElement('div');
        eventItem.className = 'upcoming-event';
        
        eventItem.innerHTML = `
            <div class="event-date">
                <div class="day">${event.date.getDate()}</div>
                <div class="month">${event.date.toLocaleDateString('en-US', { month: 'short' })}</div>
            </div>
            <div class="event-details">
                <h6>${event.name}</h6>
                <p>${event.date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })}</p>
            </div>
        `;
        
        upcomingEvents.appendChild(eventItem);
    });
}

function loadSportsPreferences() {
    const sportsPreferences = document.getElementById('sportsPreferences');
    const uniqueSports = calculateUniqueSports();
    
    if (uniqueSports === 0) {
        sportsPreferences.innerHTML = `
            <div class="empty-state">
                <i class="fas fa-heart"></i>
                <p>No favorite sports yet</p>
                <small>Play different sports to build your preferences</small>
            </div>
        `;
        return;
    }
    
    const userRegistrations = JSON.parse(localStorage.getItem('userEventRegistrations') || '{}');
    const sportsSet = new Set();
    
    Object.values(userRegistrations).forEach(registration => {
        const eventName = registration.eventName.toLowerCase();
        if (eventName.includes('basketball')) sportsSet.add('Basketball');
        else if (eventName.includes('football')) sportsSet.add('Football');
        else if (eventName.includes('padel')) sportsSet.add('Padel');
        else if (eventName.includes('volleyball')) sportsSet.add('Volleyball');
        else if (eventName.includes('tennis')) sportsSet.add('Tennis');
    });
    
    const sports = Array.from(sportsSet);
    
    sports.forEach(sport => {
        const sportTag = document.createElement('span');
        sportTag.className = 'sport-tag';
        sportTag.innerHTML = `<i class="fas fa-heart me-1"></i>${sport}`;
        sportsPreferences.appendChild(sportTag);
    });
}

function getTimeAgo(date) {
    const now = new Date();
    const diffInSeconds = Math.floor((now - date) / 1000);
    
    if (diffInSeconds < 60) return 'Just now';
    if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)} minutes ago`;
    if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)} hours ago`;
    if (diffInSeconds < 2592000) return `${Math.floor(diffInSeconds / 86400)} days ago`;
    return date.toLocaleDateString();
}

function shareProfile() {
    const userFullName = localStorage.getItem('userFullName') || 'AUS Student';
    if (navigator.share) {
        navigator.share({
            title: `${userFullName}'s Sports Profile`,
            text: `Check out ${userFullName}'s sports achievements on AUS Sports Hub!`,
            url: window.location.href
        });
    } else {
        alert('Profile sharing is available on supported browsers. For now, you can copy the link manually.');
    }
}

function createSampleData() {
    const currentUser = getCurrentUser();
    if (!currentUser) return;
    
    const userRegistrations = getUserEventRegistrations();
    const userBookings = getCourtBookings();
    
    if (Object.keys(userRegistrations).length === 0) {
        const sampleRegistrations = {
            'basketball-tournament': {
                eventName: 'Inter-College Basketball Tournament',
                registeredAt: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(),
                userId: currentUser.id,
                userFullName: currentUser.fullName
            },
            'football-friendly': {
                eventName: 'Football Friendly Match', 
                registeredAt: new Date(Date.now() - 5 * 24 * 60 * 60 * 1000).toISOString(),
                userId: currentUser.id,
                userFullName: currentUser.fullName
            }
        };
        localStorage.setItem(`userEventRegistrations_${currentUser.id}`, JSON.stringify(sampleRegistrations));
    }
    
    if (userBookings.length === 0) {
        const sampleBookings = [
            { 
                id: 'booking-' + Date.now(),
                sport: 'basketball', 
                court: 'Basketball Court 1',
                date: '2025-10-20', 
                time: '15:00',
                duration: 1.5,
                players: 4,
                requests: '',
                bookedAt: new Date(Date.now() - 1 * 24 * 60 * 60 * 1000).toISOString(),
                status: 'completed'
            },
            { 
                id: 'booking-' + (Date.now() + 1),
                sport: 'padel', 
                court: 'Padel Court 3',
                date: '2025-10-22', 
                time: '16:30',
                duration: 1,
                players: 2,
                requests: 'Need rackets',
                bookedAt: new Date().toISOString(),
                status: 'upcoming'
            }
        ];
        localStorage.setItem(`userCourtBookings_${currentUser.id}`, JSON.stringify(sampleBookings));
    }
    
    setTimeout(() => {
        loadUserStats();
    }, 500);
}

setTimeout(() => {
    if (localStorage.getItem('userLoggedIn') === 'true') {
        createSampleData();
    }
}, 1000);

function setupRealTimeUpdates() {
    window.addEventListener('profileDataUpdated', function() {
        console.log('Profile data updated - refreshing stats');
        loadUserStats();
    });
    
    window.addEventListener('storage', function(e) {
        if (e.key === 'profileNeedsRefresh') {
            console.log('Profile needs refresh from another tab');
            loadUserStats();
        }
    });
    
    const needsRefresh = localStorage.getItem('profileNeedsRefresh');
    if (needsRefresh) {
        localStorage.removeItem('profileNeedsRefresh');
        loadUserStats();
    }
    
    setInterval(() => {
        loadUserStats();
    }, 30000);
}

document.addEventListener('DOMContentLoaded', function() {
    checkUserLoginAndLoadProfile();
    
    setupRealTimeUpdates();
    
    document.querySelector('.btn-edit-profile').addEventListener('click', function() {
        openEditProfileModal();
    });
});

function getCurrentUser() {
    const userData = localStorage.getItem('currentUser');
    if (userData) {
        try {
            return JSON.parse(userData);
        } catch (e) {
            console.error('Error parsing user data:', e);
        }
    }
    
    const userId = localStorage.getItem('userId');
    const userFullName = localStorage.getItem('userFullName');
    
    if (userId) {
        return {
            id: userId,
            fullName: userFullName,
            username: localStorage.getItem('username') || 'User'
        };
    }
    
    return null;
}