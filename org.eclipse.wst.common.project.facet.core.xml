<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AUS Sports Hub - Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="profile.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="../homepage/homepage.html">
                <i class="fas fa-running me-2"></i>
                AUS Sports Hub
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="../homepage/homepage.html">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="../booking/booking.html">Booking</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="../events/events.html">Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="profile.html">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="profile-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-2">
                    <div class="profile-avatar">
                        <i class="fas fa-user-circle"></i>
                    </div>
                </div>
                <div class="col-md-6">
                    <h1 id="userFullName" class="display-5 fw-bold">Loading...</h1>
                    <p class="lead mb-2" id="userRole">Student at American University of Sharjah</p>
                    <p class="text-light" id="userStudentId">Student ID: Loading...</p>
                    <div class="member-since">
                        <i class="fas fa-calendar-alt me-2"></i>
                        Member since <span id="memberSince">2024</span>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    <button class="btn btn-outline-light btn-edit-profile">
                        <i class="fas fa-edit me-2"></i>Edit Profile
                    </button>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <h2 class="section-title mb-4">My Sports Statistics</h2>
            <div class="row">
                <div class="col-md-8">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="stat-content">
                                <h3 id="eventsRegistered">0</h3>
                                <p>Events Registered</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-basketball-ball"></i>
                            </div>
                            <div class="stat-content">
                                <h3 id="courtsBooked">0</h3>
                                <p>Courts Booked</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-trophy"></i>
                            </div>
                            <div class="stat-content">
                                <h3 id="eventsAttended">0</h3>
                                <p>Events Attended</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <div class="stat-content">
                                <h3 id="sportsPlayed">0</h3>
                                <p>Sports Played</p>
                            </div>
                        </div>
                    </div>

                    <div class="progress-section mt-5">
                        <h4 class="mb-3">Activity Progress</h4>
                        <div class="progress-item">
                            <div class="progress-label">
                                <span>Monthly Goal</span>
                                <span id="monthlyProgress">0/8 events</span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" id="monthlyProgressBar" style="width: 0%"></div>
                            </div>
                        </div>
                        <div class="progress-item">
                            <div class="progress-label">
                                <span>Sports Variety</span>
                                <span id="sportsVariety">0/5 sports</span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" id="sportsProgressBar" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>

                    <div class="recent-activity mt-5">
                        <h4 class="mb-3">Recent Activity</h4>
                        <div class="activity-list" id="recentActivity"></div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="sidebar-card">
                        <h5 class="sidebar-title">
                            <i class="fas fa-calendar-day me-2"></i>
                            Upcoming Events
                        </h5>
                        <div class="upcoming-events" id="upcomingEvents"></div>
                    </div>

                    <div class="sidebar-card mt-4">
                        <h5 class="sidebar-title">
                            <i class="fas fa-heart me-2"></i>
                            Favorite Sports
                        </h5>
                        <div class="sports-preferences" id="sportsPreferences"></div>
                    </div>

                    <div class="sidebar-card mt-4">
                        <h5 class="sidebar-title">
                            <i class="fas fa-bolt me-2"></i>
                            Quick Actions
                        </h5>
                        <div class="quick-actions">
                            <button class="btn btn-primary btn-sm w-100 mb-2" onclick="location.href='../booking/booking.html'">
                                <i class="fas fa-calendar-plus me-2"></i>Book a Court
                            </button>
                            <button class="btn btn-success btn-sm w-100 mb-2" onclick="location.href='../events/events.html'">
                                <i class="fas fa-user-plus me-2"></i>Join Event
                            </button>
                            <button class="btn btn-warning btn-sm w-100" onclick="shareProfile()">
                                <i class="fas fa-share-alt me-2"></i>Share Profile
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-running me-2"></i>AUS Sports Hub</h5>
                    <p>American University of Sharjah's premier sports booking and management platform.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="../homepage/homepage.html" class="text-light">Home</a></li>
                        <li><a href="../booking/booking.html" class="text-light">Book a Court</a></li>
                        <li><a href="../events/events.html" class="text-light">Events</a></li>
                        <li><a href="profile.html" class="text-light">Profile</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5>Contact Us</h5>
                    <p><i class="fas fa-map-marker-alt me-2"></i> American University of Sharjah</p>
                    <p><i class="fas fa-phone me-2"></i> +971 6 515 5555</p>
                    <p><i class="fas fa-envelope me-2"></i> sports@aus.edu</p>
                </div>
            </div>
            <hr class="bg-light">
            <div class="text-center">
                <p>&copy; 2025 AUS Sports Hub. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="profile.js"></script>
</body>
</html>