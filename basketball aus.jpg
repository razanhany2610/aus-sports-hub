:root {
    --aus-maroon: #7B1624;
    --aus-maroon-dark: #5A0F18;
    --aus-gold: #CBAA2C;
    --aus-teal: #4a9b8e;
    --aus-dark: #1a1a1a;
    --aus-light: #f8f9fa;
    --aus-white: #ffffff;
    --aus-gray: #6c757d;
    --aus-border: #e9ecef;
    --aus-success: #28a745;
    --aus-warning: #ffc107;
    --aus-danger: #dc3545;
}

body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background-color: var(--aus-light);
    color: var(--aus-dark);
    line-height: 1.6;
}

.navbar {
    background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 20px rgba(123, 22, 36, 0.15);
}

.navbar-brand, .nav-link {
    color: white !important;
    transition: all 0.3s ease;
}

.nav-link:hover {
    color: var(--aus-gold) !important;
    transform: translateY(-1px);
}

.nav-link.active {
    color: var(--aus-gold) !important;
    position: relative;
}

.nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 30px;
    height: 2px;
    background: var(--aus-gold);
}

.page-header {
    background: linear-gradient(135deg, rgba(123, 22, 36, 0.9) 0%, rgba(90, 15, 24, 0.85) 100%), 
                url('../img/sports complex.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    color: white;
    padding: 140px 0;
    position: relative;
    overflow: hidden;
}

.page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
}

.page-header .container {
    position: relative;
    z-index: 2;
    text-align: center;
}

.btn-primary {
    background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
    border: none;
    color: white;
    box-shadow: 0 4px 15px rgba(123, 22, 36, 0.3);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(123, 22, 36, 0.4);
    background: linear-gradient(135deg, var(--aus-maroon-dark) 0%, var(--aus-maroon) 100%);
}

.btn-success {
    background: linear-gradient(135deg, var(--aus-success) 0%, #1e7e34 100%);
    border: none;
}

.section-title {
    color: var(--aus-maroon);
    font-weight: 700;
    margin-bottom: 30px;
    position: relative;
    padding-bottom: 15px;
}

.section-title:after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, var(--aus-gold) 0%, var(--aus-teal) 100%);
    border-radius: 2px;
}

.events-filter {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

.filter-btn {
    background: var(--aus-white);
    border: 2px solid var(--aus-border);
    padding: 0.75rem 1.5rem;
    border-radius: 25px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 500;
}

.filter-btn:hover {
    border-color: var(--aus-maroon);
    transform: translateY(-2px);
}

.filter-btn.active {
    background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
    color: white;
    border-color: var(--aus-maroon);
    box-shadow: 0 4px 15px rgba(123, 22, 36, 0.3);
}

.event-card {
    background: var(--aus-white);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-left: 4px solid var(--aus-maroon);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    margin-bottom: 1.5rem;
}

.event-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.event-title {
    color: var(--aus-maroon);
    font-weight: 700;
    margin-bottom: 1rem;
}

.event-sport-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
}

.event-details {
    color: var(--aus-gray);
    margin-bottom: 1.5rem;
}

.event-organizer, .event-location, .event-time {
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.event-description {
    background: var(--aus-light);
    padding: 1rem;
    border-radius: 8px;
    margin-top: 1rem;
    border-left: 3px solid var(--aus-gold);
}

.players-info {
    margin: 1.5rem 0;
}

.progress {
    height: 8px;
    background-color: var(--aus-border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
}

.progress-bar {
    background: linear-gradient(90deg, var(--aus-maroon) 0%, var(--aus-gold) 100%);
}

.players-count {
    font-size: 0.9rem;
    color: var(--aus-gray);
    text-align: center;
}

.join-btn {
    background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
    border: none;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 25px;
    font-weight: 600;
    transition: all 0.3s ease;
    width: 100%;
}

.join-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(123, 22, 36, 0.4);
}

.join-btn:disabled {
    background: var(--aus-gray);
    cursor: not-allowed;
}

.join-btn.registered {
    background: linear-gradient(135deg, var(--aus-success) 0%, #1e7e34 100%);
}

.registered-badge {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
    padding: 0.75rem;
    border-radius: 8px;
    margin-top: 1rem;
    text-align: center;
    font-weight: 600;
    border: 1px solid #c3e6cb;
}

.create-event-btn {
    background: linear-gradient(135deg, var(--aus-success) 0%, #1e7e34 100%);
    border: none;
    color: white;
    padding: 1rem 2rem;
    border-radius: 25px;
    font-weight: 600;
    transition: all 0.3s ease;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
}

.create-event-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(40, 167, 69, 0.4);
}

.no-events {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--aus-white);
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

footer {
    background: linear-gradient(135deg, var(--aus-dark) 0%, #2a2a2a 100%);
    color: white;
    padding: 4rem 0 2rem;
    margin-top: 4rem;
}

footer h5 {
    color: var(--aus-gold);
    font-weight: 600;
    margin-bottom: 1.5rem;
}

footer a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
}

footer a:hover {
    color: var(--aus-gold);
}

.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 600ms ease, transform 600ms ease;
}

.reveal.active {
    opacity: 1;
    transform: none;
}

@media (max-width: 768px) {
    .page-header {
        padding: 100px 0;
    }
    
    .events-filter {
        justify-content: center;
    }
    
    .filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
    }
    
    .event-card {
        padding: 1.5rem;
    }
}

.modal-content {
    border-radius: 16px;
    border: none;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
}

.modal-header {
    background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
    color: white;
    border-radius: 16px 16px 0 0;
    border-bottom: none;
    padding: 1.5rem 2rem;
}

.modal-title {
    font-weight: 600;
    font-size: 1.25rem;
}

.modal-body {
    padding: 2rem;
}

.modal-footer {
    border-top: 1px solid var(--aus-border);
    padding: 1.5rem 2rem;
}

.form-label {
    font-weight: 600;
    color: var(--aus-dark);
    margin-bottom: 0.5rem;
}

.form-control, .form-select {
    border: 2px solid var(--aus-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    transition: all 0.3s ease;
}

.form-control:focus, .form-select:focus {
    border-color: var(--aus-maroon);
    box-shadow: 0 0 0 0.2rem rgba(123, 22, 36, 0.15);
}

.form-check-input:checked {
    background-color: var(--aus-maroon);
    border-color: var(--aus-maroon);
}

.btn-close {
    filter: invert(1);
}

@media (max-width: 768px) {
    .modal-body {
        padding: 1.5rem;
    }
    
    .modal-header, .modal-footer {
        padding: 1rem 1.5rem;
    }
}

@media (max-width: 768px) {
    .page-header {
        padding: 80px 0;
        background-attachment: scroll;
    }
    
    .page-header h1 {
        font-size: 2.2rem;
    }
    
    .create-event-btn {
        width: 100%;
        padding: 12px 20px;
        font-size: 1.1rem;
    }
    
    .events-filter {
        justify-content: center;
        gap: 8px;
        margin-bottom: 1.5rem;
    }
    
    .filter-btn {
        padding: 10px 15px;
        font-size: 0.9rem;
        flex: 1;
        min-width: auto;
        text-align: center;
    }
    
    .event-card {
        padding: 1.5rem;
        margin-bottom: 1.2rem;
    }
    
    .event-title {
        font-size: 1.3rem;
    }
    
    .event-details {
        font-size: 0.9rem;
    }
    
    .join-btn {
        padding: 12px 20px;
        font-size: 1rem;
    }
}

@media (max-width: 576px) {
    .page-header h1 {
        font-size: 1.8rem;
    }
    
    .page-header .lead {
        font-size: 1rem;
    }
    
    .events-filter {
        flex-direction: column;
    }
    
    .filter-btn {
        margin-bottom: 5px;
    }
    
    .event-card {
        padding: 1.2rem;
    }
    
    .event-header {
        text-align: center;
    }
    
    .event-sport-badge {
        display: block;
        width: fit-content;
        margin-left: auto;
        margin-right: auto;
    }
    
    .modal-dialog {
        margin: 10px;
    }
    
    .modal-body {
        padding: 1.2rem;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .events-filter {
        justify-content: flex-start;
    }
    
    .filter-btn {
        flex: 0 1 auto;
    }
}

@media (max-width: 768px) {
    .form-control, .form-select {
        font-size: 16px;
    }
    
    .modal .row {
        margin-left: -8px;
        margin-right: -8px;
    }
    
    .modal .col-md-6 {
        padding-left: 8px;
        padding-right: 8px;
    }
}

@media (max-width: 576px) {
    .event-organizer,
    .event-location,
    .event-time {
        justify-content: center;
        text-align: center;
    }
    
    .players-info {
        text-align: center;
    }
}

@media (max-width: 768px) {
    .modal-header,
    .modal-footer {
        padding: 1rem 1.2rem;
    }
}

@media (max-width: 768px) {
    .navbar-collapse {
        background: linear-gradient(135deg, var(--aus-maroon) 0%, var(--aus-maroon-dark) 100%);
        padding: 1rem;
        border-radius: 0 0 10px 10px;
        margin-top: 10px;
    }
    
    .navbar-nav .nav-item {
        margin: 5px 0;
    }
    
    .navbar-toggler {
        border: none;
        padding: 4px 8px;
    }
    
    .navbar-toggler:focus {
        box-shadow: none;
    }
}

.d-mobile-block { display: block !important; }
.d-mobile-none { display: none !important; }
.d-tablet-block { display: block !important; }
.d-tablet-none { display: none !important; }

@media (max-width: 768px) {
    .d-mobile-block { display: block !important; }
    .d-mobile-none { display: none !important; }
    .d-tablet-block { display: block !important; }
    .d-tablet-none { display: none !important; }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .d-mobile-block { display: block !important; }
    .d-mobile-none { display: none !important; }
    .d-tablet-block { display: block !important; }
    .d-tablet-none { display: none !important; }
}

.text-mobile-center { text-align: center !important; }
.text-mobile-left { text-align: left !important; }
.text-mobile-right { text-align: right !important; }

@media (max-width: 768px) {
    .text-mobile-center { text-align: center !important; }
    .text-mobile-left { text-align: left !important; }
    .text-mobile-right { text-align: right !important; }
}